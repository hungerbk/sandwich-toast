{
  "name": "sandwich-toast",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "description": "A playful React toast library with layered sandwich-ingredient illustrations.",
  "main": "./dist/sandwich-toast.cjs.js",
  "module": "./dist/sandwich-toast.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/sandwich-toast.es.js",
      "require": "./dist/sandwich-toast.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.ts",
    "build:demo": "tsc -b tsconfig.app.json && vite build --config vite.config.ts",
    "typecheck": "tsc -b",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-dts": "^5.0.3"
  }
}
